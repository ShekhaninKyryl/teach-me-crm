generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String  @id @default(uuid())
  name         String
  email        String? @unique
  passwordHash String?

  resetPasswordToken String?
  resetPasswordExpires DateTime?

  avatar String?

  phone    String?
  viber    String?
  telegram String?
  whatsapp String?

  tutorProfile    TutorProfile?
  createdSubjects Subject[]

  studentsAsUser Student[] @relation("StudentUser")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model TutorProfile {
  userId String @id
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  subjects     TutorSubject[]
  formats      String[]
  rating       Float?
  price        Int
  location     String?
  bio          String?
  availability Json?
  maxStudents  Int?

  students Student[] @relation("TutorStudents")
  events   Event[]   @relation("TutorEvents")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tutor_profiles")
}

model Subject {
  id     String  @id @default(uuid())
  label  String  @unique
  faIcon String?

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tutors TutorSubject[]

  @@map("subjects")
}

model TutorSubject {
  tutorUserId String
  subjectId   String

  tutor   TutorProfile @relation(fields: [tutorUserId], references: [userId], onDelete: Cascade)
  subject Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([tutorUserId, subjectId])
  @@index([subjectId])
  @@map("tutor_subjects")
}

model Student {
  id String @id @default(uuid())

  tutorUserId String
  tutor       TutorProfile @relation("TutorStudents", fields: [tutorUserId], references: [userId], onDelete: Cascade)

  userId String?
  user   User?   @relation("StudentUser", fields: [userId], references: [id], onDelete: SetNull)

  name  String
  color String?

  events Event[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tutorUserId, userId])
  @@index([tutorUserId])
  @@index([userId])
  @@map("students")
}

enum EventStatus {
  PENDING
  RESCHEDULED
  CANCELLED
  COMPLETED
  PAID
}

model Event {
  id String @id @default(uuid())

  tutorUserId String
  tutor       TutorProfile @relation("TutorEvents", fields: [tutorUserId], references: [userId], onDelete: Cascade)

  studentId String?
  student   Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)

  title       String
  description String?

  startAt DateTime?
  endAt   DateTime?

  weekly Boolean     @default(false)
  status EventStatus @default(PENDING)

  price Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tutorUserId, startAt])
  @@index([studentId, startAt])
  @@map("events")
}
